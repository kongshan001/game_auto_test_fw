# GLM API 配置
# 获取 API Key: https://open.bigmodel.cn/

GLM_API_KEY=your-api-key-here

# 模型选择
# glm-4.6v: 旗舰版 (106B)，最强视觉理解
# glm-4.6v-flashx: 轻量高速版 (9B)
# glm-4.6v-flash: 完全免费版
GLM_MODEL=glm-4.6v-flash

# 是否开启深度思考模式
GLM_THINKING=true

# ==================== 游戏配置 ====================

# 游戏名称（用于日志）
GAME_NAME=YourGame

# 游戏可执行文件路径
GAME_EXE_PATH=C:\Games\YourGame\game.exe

# 进程名（用于查找窗口，如 "game.exe"）
# 如果不指定，将通过启动的进程自动查找
GAME_PROCESS_NAME=

# 窗口标题（部分匹配，用于查找窗口）
# 如果不指定，将通过进程自动查找
GAME_WINDOW_TITLE=

# ==================== 测试账号 ====================

TEST_ACCOUNT=your_account
TEST_PASSWORD=your_password

# ==================== 其他配置 ====================

# 最大步数
MAX_STEPS=30

# 决策超时（秒）
DECISION_TIMEOUT=60

# 重试次数
RETRY_TIMES=3

# 日志级别
LOG_LEVEL=INFO
